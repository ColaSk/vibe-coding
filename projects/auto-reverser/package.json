{
  "name": "auto-reverser",
  "version": "1.0.0",
  "description": "Chrome浏览器自动逆向分析工具",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "lint": "eslint src/",
    "test": "jest"
  },
  "keywords": [
    "reverse",
    "api",
    "encryption",
    "chrome",
    "devtools"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@babel/generator": "^7.23.0",
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "@babel/types": "^7.23.0",
    "chrome-remote-interface": "^0.33.0",
    "crypto-js": "^4.2.0",
    "electron-store": "^8.1.0",
    "ollama": "^0.6.3",
    "puppeteer": "^24.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^8.53.0",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.auto-reverser.app",
    "productName": "Auto Reverser",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
